# Base URL of the Kleannr API (must include the /api/v1 prefix in prod).
#
# Dev:  /api/v1                          — relative; vite.config.ts proxies it to
#                                           https://api.kleannr.com server-side (no CORS).
# Prod: https://api.kleannr.com/api/v1   — absolute; the deployed origin must be
#                                           allowed by the backend's CORS config.
VITE_API_BASE_URL=/api/v1
